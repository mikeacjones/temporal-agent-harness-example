ANTHROPIC_API_KEY=
# Optional. Point Anthropic SDK calls at a compatible gateway such as LiteLLM.
ANTHROPIC_BASE_URL=
SIMPLE_CHAT_JWT_SECRET=
# Local-only auth. Keep disabled in shared or deployed environments. When this
# is enabled and Google OAuth is not configured, the API registers
# /api/auth/local/login and the UI shows a local username/password form.
SIMPLE_CHAT_LOCAL_AUTH_ENABLED=0
SIMPLE_CHAT_LOCAL_AUTH_USERNAME=demo
SIMPLE_CHAT_LOCAL_AUTH_PASSWORD=demo
# Google OAuth is used for shared/deployed environments. If Google OAuth is
# configured, local auth is ignored and /api/auth/local/login is not registered.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Leave GOOGLE_OAUTH_REDIRECT_URI unset to auto-derive from the incoming request's
# scheme + host (the request's base URL plus /oauth/google/callback). Set it
# explicitly only when you need to override that behavior.
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_ALLOWED_DOMAIN=temporal.io
# When fronted by a reverse proxy on a different host, list the proxy IPs
# (comma-separated) so uvicorn honors X-Forwarded-Proto/Host. Use "*" to trust all.
FORWARDED_ALLOW_IPS=127.0.0.1
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/oauth/github/callback
GITHUB_OAUTH_SCOPES=read:user,user:email,public_repo,repo
# Optional research tools. GOOGLE_API_KEY enables the Google-backed research
# tools when the corresponding APIs are enabled in the Google Cloud project.
# For local SearXNG Docker setup, see docs/local-development.md.
GOOGLE_API_KEY=
SIMPLE_CHAT_SEARXNG_BASE_URL=
TEMPORAL_API_KEY=
TEMPORAL_NAMESPACE=
TEMPORAL_ENDPOINT=
TEMPORAL_TLS=
# Worker task queue + workflow-id prefix. Leave at the defaults for prod; the
# isolated test stack (deploy/testing/) overrides these to run in the same
# namespace without colliding with prod.
SIMPLE_CHAT_TASK_QUEUE=simple-chat-agent
SIMPLE_CHAT_WORKER_VERSION=1.0.0
# Disable worker versioning for local/dev defaults. Shared deployments should
# leave versioning enabled unless they intentionally opt out.
SIMPLE_CHAT_WORKER_VERSIONING_ENABLED=0
SIMPLE_CHAT_WORKFLOW_PREFIX=
# The Good Place censor: rewrite swears into wholesome substitutes inside the
# LLM guards (default on). Set to 0 to disable.
SIMPLE_CHAT_GOOD_PLACE=1
